# ==========================================
# AI Clinical CDSS - Root GitIgnore
# Covers Python backend and React/Vite frontend
# ==========================================

# --- Python / Backend ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
.venv/
venv/
ENV/
env/
Active_Resources/

# Environment configurations (Keep .env.example, ignore actual .env)
.env
backend/.env
frontend/.env
*.env
*.env.local
*.env.development.local
*.env.test.local
*.env.production.local

# Database files
backend/app/database/database.db
*.db
*.sqlite3

# Serialized Machine Learning models / artifacts
backend/app/models/disease_model.pkl
*.pkl
*.joblib

# --- Node / Frontend ---
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
node_modules/
dist/
dist-ssr/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Editors / OS / IDEs ---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
Desktop.ini
